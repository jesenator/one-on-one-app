generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  superAdmin Boolean  @default(false)
  createdAt  DateTime @default(now())

  attendances      RetreatAttendance[]
  availability     Availability[]
  requestsSent     MeetingRequest[]    @relation("from")
  requestsReceived MeetingRequest[]    @relation("to")
  retreatAdmins    RetreatAdmin[]
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  email     String
  name      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model Retreat {
  id                 String   @id // slug like "west-coast-ea-2026"
  name               String
  timezone           String
  active             Boolean  @default(true)
  slotsStart         String   // "2026-04-15T08:00" (fake-UTC wall-clock)
  slotsEnd           String
  dayStart           String   @default("08:00")
  dayEnd             String   @default("22:00")
  granularityMinutes Int      @default(30)
  highlightedSlots   String[]
  createdAt          DateTime @default(now())

  attendances RetreatAttendance[]
  admins      RetreatAdmin[]
}

model RetreatAdmin {
  id        String @id @default(cuid())
  userId    String
  retreatId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  retreat Retreat @relation(fields: [retreatId], references: [id], onDelete: Cascade)

  @@unique([userId, retreatId])
}

model RetreatAttendance {
  id        String   @id @default(cuid())
  userId    String
  retreatId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  retreat Retreat @relation(fields: [retreatId], references: [id], onDelete: Cascade)

  @@unique([userId, retreatId])
  @@index([retreatId])
}

model Availability {
  id        String   @id @default(cuid())
  userId    String
  retreatId String
  slotStart DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, retreatId, slotStart])
  @@index([retreatId, slotStart])
}

enum RequestStatus {
  pending
  accepted
  declined
  cancelled
}

model MeetingRequest {
  id         String        @id @default(cuid())
  retreatId  String
  fromUserId String
  toUserId   String
  slotStart  DateTime
  status     RequestStatus @default(pending)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  from User @relation("from", fields: [fromUserId], references: [id], onDelete: Cascade)
  to   User @relation("to", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([retreatId, slotStart])
  @@index([fromUserId])
  @@index([toUserId])
}
